project Adacrash is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("adacrash.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2012", "-O2", "-gnatn", "-Wall");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use ("-lSDL2");
   end Linker;

   package Builder is
      for Executable ("adacrash.adb") use "adacrash";
   end Builder;

end Adacrash;
